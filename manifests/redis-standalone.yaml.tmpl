apiVersion: v1
kind: Namespace
metadata:
  name: __NAMESPACE__
  labels:
    app.kubernetes.io/name: redis
    app.kubernetes.io/instance: __APP_NAME__
---
apiVersion: v1
kind: Secret
metadata:
  name: __APP_NAME__-auth
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: redis
    app.kubernetes.io/instance: __APP_NAME__
type: Opaque
data:
  redis-password: __REDIS_PASSWORD_B64__
---
apiVersion: v1
kind: Service
metadata:
  name: __SERVICE_NAME__
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: redis
    app.kubernetes.io/instance: __APP_NAME__
spec:
  type: __SERVICE_TYPE__
  selector:
    app.kubernetes.io/name: redis
    app.kubernetes.io/instance: __APP_NAME__
  ports:
  - name: redis
    port: 6379
    targetPort: redis
    protocol: TCP
__NODE_PORT_BLOCK__
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: __APP_NAME__
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: redis
    app.kubernetes.io/instance: __APP_NAME__
spec:
  serviceName: __SERVICE_NAME__
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: redis
      app.kubernetes.io/instance: __APP_NAME__
  template:
    metadata:
      labels:
        app.kubernetes.io/name: redis
        app.kubernetes.io/instance: __APP_NAME__
    spec:
      terminationGracePeriodSeconds: 30
      securityContext:
        fsGroup: 999
      containers:
      - name: redis
        image: __IMAGE__
        imagePullPolicy: __IMAGE_PULL_POLICY__
        ports:
        - name: redis
          containerPort: 6379
          protocol: TCP
        env:
        - name: REDIS_PASSWORD
          valueFrom:
            secretKeyRef:
              name: __APP_NAME__-auth
              key: redis-password
        readinessProbe:
          exec:
            command:
            - /usr/local/bin/redis-healthcheck
          initialDelaySeconds: 10
          periodSeconds: 10
          timeoutSeconds: 5
          failureThreshold: 6
        livenessProbe:
          exec:
            command:
            - /usr/local/bin/redis-healthcheck
          initialDelaySeconds: 30
          periodSeconds: 20
          timeoutSeconds: 5
          failureThreshold: 6
        resources:
          requests:
            cpu: 100m
            memory: 256Mi
          limits:
            cpu: "2"
            memory: 2Gi
        volumeMounts:
        - name: data
          mountPath: /data
  volumeClaimTemplates:
  - metadata:
      name: data
      labels:
        app.kubernetes.io/name: redis
        app.kubernetes.io/instance: __APP_NAME__
    spec:
      accessModes:
      - ReadWriteOnce
__STORAGE_CLASS_BLOCK__
      resources:
        requests:
          storage: __STORAGE_SIZE__
